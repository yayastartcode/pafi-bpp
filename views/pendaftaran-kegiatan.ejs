<section class="max-w-2xl mx-auto px-4 py-12">
    <a href="/kegiatan" class="text-text-muted hover:text-header text-sm mb-6 inline-flex items-center gap-1"><i
            class="fas fa-arrow-left"></i> Kembali ke Kegiatan</a>

    <div class="text-center mb-8">
        <h1 class="text-3xl font-bold mb-3">Pendaftaran <span class="text-header">Kegiatan</span></h1>
        <p class="text-text-muted">
            <%= kegiatan.nama_kegiatan %>
        </p>
    </div>

    <form method="POST" action="/kegiatan/<%= kegiatan.id %>/daftar" enctype="multipart/form-data"
        class="card rounded-2xl p-8 space-y-5">
        <div class="stat-card p-4 mb-4">
            <p class="text-sm text-text-muted"><i class="fas fa-layer-group mr-1"></i> Bidang: <strong class="text-text">
                    <%= kegiatan.bidang || '-' %>
                </strong></p>
            <p class="text-sm text-text-muted mt-1"><i class="fas fa-users mr-1"></i> Target: <strong class="text-text">
                    <%= kegiatan.target_peserta || '-' %>
                </strong> peserta</p>
        </div>
        <div>
            <label class="block text-sm font-medium text-text mb-2">Nama Peserta <span
                    class="text-red-600">*</span></label>
            <input type="text" name="nama_peserta" class="form-input" required>
        </div>
        <div>
            <label class="block text-sm font-medium text-text mb-2">No. WhatsApp <span
                    class="text-red-600">*</span></label>
            <input type="text" name="no_whatsapp" class="form-input" placeholder="08xxxxxxxxxx" required>
        </div>
        <div>
            <label class="block text-sm font-medium text-text mb-2">Tempat Bekerja</label>
            <input type="text" name="tempat_bekerja" class="form-input">
        </div>
        <div>
            <label class="block text-sm font-medium text-text mb-2">Upload Iuran Lunas</label>
            <input type="file" name="upload_iuran" accept="image/*"
                class="form-input file:mr-4 file:py-1 file:px-3 file:rounded file:border-0 file:text-sm file:bg-blue-50 file:text-header">
        </div>
        <div>
            <label class="block text-sm font-medium text-text mb-2">Upload Bukti Transfer Pendaftaran</label>
            <input type="file" name="upload_bukti_transfer" accept="image/*"
                class="form-input file:mr-4 file:py-1 file:px-3 file:rounded file:border-0 file:text-sm file:bg-blue-50 file:text-header">
        </div>
        <input type="hidden" name="kegiatan_id" value="<%= kegiatan.id %>">
        <button type="submit" class="btn-primary w-full justify-center py-3"><i class="fas fa-paper-plane"></i> Daftar
            Kegiatan</button>
    </form>
</section>