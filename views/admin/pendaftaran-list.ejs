<h2 class="text-2xl font-bold mb-6">Pendaftaran <span class="text-header">Kegiatan</span></h2>
<div class="card rounded-xl overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full data-table">
            <thead>
                <tr>
                    <th class="px-4 py-3 text-left">Nama Peserta</th>
                    <th class="px-4 py-3 text-left">Kegiatan</th>
                    <th class="px-4 py-3 text-left">WhatsApp</th>
                    <th class="px-4 py-3 text-left">Tempat Bekerja</th>
                    <th class="px-4 py-3 text-center">Iuran</th>
                    <th class="px-4 py-3 text-center">Transfer</th>
                    <th class="px-4 py-3 text-left">Tanggal</th>
                </tr>
            </thead>
            <tbody>
                <% if (items.length> 0) { items.forEach(function(p) { %>
                    <tr>
                        <td class="px-4 py-3 font-medium text-text">
                            <%= p.nama_peserta %>
                        </td>
                        <td class="px-4 py-3 text-sm text-text-muted">
                            <%= p.nama_kegiatan || '-' %>
                        </td>
                        <td class="px-4 py-3 text-sm text-text-muted">
                            <%= p.no_whatsapp || '-' %>
                        </td>
                        <td class="px-4 py-3 text-sm text-text-muted">
                            <%= p.tempat_bekerja || '-' %>
                        </td>
                        <td class="px-4 py-3 text-center">
                            <% if (p.upload_iuran) { %><a href="/uploads/<%= p.upload_iuran %>" target="_blank"
                                    class="text-header"><i class="fas fa-eye"></i></a>
                                <% } else { %>-<% } %>
                        </td>
                        <td class="px-4 py-3 text-center">
                            <% if (p.upload_bukti_transfer) { %><a href="/uploads/<%= p.upload_bukti_transfer %>"
                                    target="_blank" class="text-header"><i class="fas fa-eye"></i></a>
                                <% } else { %>-<% } %>
                        </td>
                        <td class="px-4 py-3 text-sm text-text-muted">
                            <%= p.created_at ? new Date(p.created_at).toLocaleDateString('id-ID') : '-' %>
                        </td>
                    </tr>
                    <% }); } else { %>
                        <tr>
                            <td colspan="7" class="px-4 py-8 text-center text-text-muted">Belum ada pendaftaran</td>
                        </tr>
                        <% } %>
            </tbody>
        </table>
    </div>
</div>