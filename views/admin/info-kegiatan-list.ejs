<div class="flex items-center justify-between mb-6">
    <h2 class="text-2xl font-bold">Info <span class="text-header">Kegiatan</span></h2>
    <a href="/admin/info-kegiatan/tambah" class="btn-primary"><i class="fas fa-plus"></i> Tambah</a>
</div>
<div class="card rounded-xl overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full data-table">
            <thead>
                <tr>
                    <th class="px-4 py-3 text-left">Nama Kegiatan</th>
                    <th class="px-4 py-3 text-left">Bidang</th>
                    <th class="px-4 py-3 text-center">Target Peserta</th>
                    <th class="px-4 py-3 text-center">Status</th>
                    <th class="px-4 py-3 text-center">Aksi</th>
                </tr>
            </thead>
            <tbody>
                <% if (items.length> 0) { items.forEach(function(k) { %>
                    <tr>
                        <td class="px-4 py-3 font-medium text-text">
                            <%= k.nama_kegiatan %>
                        </td>
                        <td class="px-4 py-3 text-sm text-text-muted">
                            <%= k.bidang || '-' %>
                        </td>
                        <td class="px-4 py-3 text-center text-sm text-text-muted">
                            <%= k.target_peserta || '-' %>
                        </td>
                        <td class="px-4 py-3 text-center">
                            <span
                                class="px-2 py-1 rounded-full text-xs <%= k.is_active ? 'bg-green-50 text-green-600' : 'bg-gray-100 text-text-muted' %>">
                                <%= k.is_active ? 'Aktif' : 'Nonaktif' %>
                            </span>
                        </td>
                        <td class="px-4 py-3 text-center flex items-center justify-center gap-2">
                            <a href="/admin/info-kegiatan/<%= k.id %>/toggle" class="text-yellow-600 text-sm"
                                title="Toggle"><i class="fas fa-sync"></i></a>
                            <a href="/admin/info-kegiatan/<%= k.id %>/hapus" class="text-red-500 text-sm"
                                onclick="return confirm('Hapus?')"><i class="fas fa-trash"></i></a>
                        </td>
                    </tr>
                    <% }); } else { %>
                        <tr>
                            <td colspan="5" class="px-4 py-8 text-center text-text-muted">Belum ada data</td>
                        </tr>
                        <% } %>
            </tbody>
        </table>
    </div>
</div>