<div class="max-w-2xl mx-auto">
    <a href="/admin/kegiatan-realisasi"
        class="text-text-muted hover:text-header text-sm mb-6 inline-flex items-center gap-1"><i
            class="fas fa-arrow-left"></i> Kembali</a>
    <h2 class="text-2xl font-bold mb-6">Tambah <span class="text-header">Kegiatan Terealisasi</span></h2>
    <form method="POST" action="/admin/kegiatan-realisasi/tambah" enctype="multipart/form-data"
        class="card rounded-2xl p-8 space-y-5">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
                <label class="block text-sm font-medium text-text mb-2">Tanggal Kegiatan</label>
                <input type="date" name="tanggal" class="form-input" required>
            </div>
            <div>
                <label class="block text-sm font-medium text-text mb-2">Jumlah Peserta</label>
                <input type="number" name="jumlah_peserta" class="form-input" placeholder="0">
            </div>
        </div>
        <div>
            <label class="block text-sm font-medium text-text mb-2">Nama Kegiatan</label>
            <input type="text" name="nama_kegiatan" class="form-input" required>
        </div>
        <div>
            <label class="block text-sm font-medium text-text mb-2">Ketua Panitia</label>
            <input type="text" name="ketua_panitia" class="form-input">
        </div>
        <% for(let i=1; i<=5; i++) { %>
            <div>
                <label class="block text-sm font-medium text-text mb-2">Foto <%= i %>
                        <%= i <=1 ? '(Wajib)' : '(Opsional)' %></label>
                <input type="file" name="foto<%= i %>" accept="image/*"
                    class="form-input file:mr-4 file:py-1 file:px-3 file:rounded file:border-0 file:text-sm file:bg-blue-50 file:text-header"
                    <%=i===1 ? 'required' : '' %>>
            </div>
            <% } %>
                <button type="submit" class="btn-primary w-full justify-center py-3"><i class="fas fa-save"></i>
                    Simpan</button>
    </form>
</div>