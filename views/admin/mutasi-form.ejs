<div class="max-w-2xl mx-auto">
    <a href="/admin/mutasi"
        class="text-text-muted hover:text-header text-sm mb-6 inline-flex items-center gap-1"><i
            class="fas fa-arrow-left"></i> Kembali</a>
    <h2 class="text-2xl font-bold mb-6">Tambah <span class="text-header">Data Mutasi</span></h2>
    <form method="POST" action="/admin/mutasi/tambah" class="card rounded-2xl p-8 space-y-5">
        <div>
            <label class="block text-sm font-medium text-text mb-2">Nama Anggota</label>
            <input type="text" name="nama_anggota" class="form-input" required>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
                <label class="block text-sm font-medium text-text mb-2">Daerah Asal</label>
                <input type="text" name="daerah_asal" class="form-input" placeholder="Daerah asal anggota">
            </div>
            <div>
                <label class="block text-sm font-medium text-text mb-2">Tujuan</label>
                <input type="text" name="tujuan" class="form-input" placeholder="Daerah tujuan">
            </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
                <label class="block text-sm font-medium text-text mb-2">Tipe Mutasi</label>
                <select name="tipe" class="form-input" required>
                    <option value="Masuk">Masuk</option>
                    <option value="Keluar">Keluar</option>
                </select>
            </div>
            <div>
                <label class="block text-sm font-medium text-text mb-2">Tanggal</label>
                <input type="date" name="tanggal" class="form-input" required>
            </div>
        </div>
        <button type="submit" class="btn-primary w-full justify-center py-3"><i class="fas fa-save"></i> Simpan</button>
    </form>
</div>