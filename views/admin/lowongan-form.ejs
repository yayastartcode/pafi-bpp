<div class="max-w-2xl mx-auto">
    <a href="/admin/lowongan"
        class="text-text-muted hover:text-header text-sm mb-6 inline-flex items-center gap-1"><i
            class="fas fa-arrow-left"></i> Kembali</a>
    <h2 class="text-2xl font-bold mb-6">Tambah <span class="text-header">Lowongan</span></h2>
    <form method="POST" action="/admin/lowongan/tambah" enctype="multipart/form-data"
        class="card rounded-2xl p-8 space-y-5">
        <div>
            <label class="block text-sm font-medium text-text mb-2">Tanggal</label>
            <input type="date" name="tanggal" class="form-input" required>
        </div>
        <div>
            <label class="block text-sm font-medium text-text mb-2">Asal Sumber</label>
            <input type="text" name="asal_sumber" class="form-input" placeholder="Sumber lowongan" required>
        </div>
        <div>
            <label class="block text-sm font-medium text-text mb-2">Upload Lowongan</label>
            <input type="file" name="upload_file"
                class="form-input file:mr-4 file:py-1 file:px-3 file:rounded file:border-0 file:text-sm file:bg-blue-50 file:text-header">
        </div>
        <button type="submit" class="btn-primary w-full justify-center py-3"><i class="fas fa-save"></i> Simpan</button>
    </form>
</div>