<a href="/admin/dashboard" class="text-text-muted hover:text-header text-sm mb-6 inline-flex items-center gap-1">
    <i class="fas fa-arrow-left"></i> Kembali
</a>

<h2 class="text-2xl font-bold mb-6">Filter: <span class="text-header">
        <%= filterType %>
    </span></h2>

<!-- Rekap -->
<div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
    <% rekap.forEach(function(r) { %>
        <a href="?<%= filterField %>=<%= encodeURIComponent(r.kategori_tempat_bekerja || '') %>"
            class="stat-card p-4 cursor-pointer hover:border-blue-300 transition-colors <%= selectedFilter === (r.kategori_tempat_bekerja || '') ? 'border-header' : '' %>">
            <p class="text-2xl font-bold text-text">
                <%= r.jumlah %>
            </p>
            <p class="text-xs text-text-muted mt-1">
                <%= r.kategori_tempat_bekerja || 'Tidak Ada Data' %>
            </p>
        </a>
        <% }); %>
</div>

<!-- Result Table -->
<% if (members.length> 0) { %>
    <div class="card rounded-xl overflow-hidden">
        <div class="px-4 py-3 border-b border-border flex items-center justify-between">
            <span class="text-sm text-text-muted">Menampilkan <%= members.length %> anggota</span>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full data-table">
                <thead>
                    <tr>
                        <th class="px-4 py-3 text-left">#</th>
                        <th class="px-4 py-3 text-left">Nama</th>
                        <th class="px-4 py-3 text-left">Tempat Bekerja</th>
                        <th class="px-4 py-3 text-left">No. KTAN</th>
                        <th class="px-4 py-3 text-left">WhatsApp</th>
                        <th class="px-4 py-3 text-center">Aksi</th>
                    </tr>
                </thead>
                <tbody>
                    <% members.forEach(function(m, i) { %>
                        <tr>
                            <td class="px-4 py-3 text-sm text-text-muted">
                                <%= i + 1 %>
                            </td>
                            <td class="px-4 py-3 font-medium text-text">
                                <%= m.nama %>
                            </td>
                            <td class="px-4 py-3 text-sm text-text-muted">
                                <%= m.tempat_bekerja || '-' %>
                            </td>
                            <td class="px-4 py-3 text-sm text-text-muted">
                                <%= m.no_ktan || '-' %>
                            </td>
                            <td class="px-4 py-3 text-sm text-text-muted">
                                <%= m.no_whatsapp || '-' %>
                            </td>
                            <td class="px-4 py-3 text-center">
                                <a href="/admin/members/<%= m.id %>"
                                    class="text-header hover:text-header text-sm"><i
                                        class="fas fa-id-card"></i></a>
                            </td>
                        </tr>
                        <% }); %>
                </tbody>
            </table>
        </div>
    </div>
    <% } else if (selectedFilter) { %>
        <div class="card rounded-xl p-8 text-center text-text-muted">
            <i class="fas fa-search text-3xl mb-3"></i>
            <p>Tidak ada data untuk filter ini</p>
        </div>
        <% } else { %>
            <div class="card rounded-xl p-8 text-center text-text-muted">
                <i class="fas fa-hand-pointer text-3xl mb-3"></i>
                <p>Klik salah satu kategori di atas untuk melihat detail</p>
            </div>
            <% } %>