<div class="max-w-2xl mx-auto">
    <a href="/admin/info-kegiatan"
        class="text-text-muted hover:text-header text-sm mb-6 inline-flex items-center gap-1"><i
            class="fas fa-arrow-left"></i> Kembali</a>
    <h2 class="text-2xl font-bold mb-6">Tambah <span class="text-header">Info Kegiatan</span></h2>
    <form method="POST" action="/admin/info-kegiatan/tambah" class="card rounded-2xl p-8 space-y-5">
        <div>
            <label class="block text-sm font-medium text-text mb-2">Nama Kegiatan</label>
            <input type="text" name="nama_kegiatan" class="form-input" required>
        </div>
        <div>
            <label class="block text-sm font-medium text-text mb-2">Bidang</label>
            <input type="text" name="bidang" class="form-input" placeholder="Bidang kegiatan">
        </div>
        <div>
            <label class="block text-sm font-medium text-text mb-2">Tujuan</label>
            <textarea name="tujuan" class="form-input" rows="3" placeholder="Tujuan kegiatan"></textarea>
        </div>
        <div>
            <label class="block text-sm font-medium text-text mb-2">Target Peserta</label>
            <input type="number" name="target_peserta" class="form-input" placeholder="0">
        </div>
        <button type="submit" class="btn-primary w-full justify-center py-3"><i class="fas fa-save"></i> Simpan</button>
    </form>
</div>