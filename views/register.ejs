<section class="bg-header text-white py-12">
    <div class="max-w-3xl mx-auto px-4 text-center">
        <h1 class="text-3xl font-bold mb-2">Pendaftaran <span class="text-cyan-200">Anggota</span></h1>
        <p class="text-white/80">Lengkapi data berikut untuk mendaftar sebagai anggota PAFI Cabang Balikpapan</p>
    </div>
</section>
<section class="max-w-3xl mx-auto px-4 -mt-8 pb-12">
    <form method="POST" action="/daftar" enctype="multipart/form-data" class="card p-8 space-y-5">

        <!-- Akun Login -->
        <h3 class="text-lg font-semibold text-header border-b border-border pb-2"><i class="fas fa-lock mr-2"></i>Akun
            Login</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
                <label class="block text-sm font-medium text-text mb-2">Username <span
                        class="text-red-500">*</span></label>
                <input type="text" name="username" class="form-input" placeholder="Username untuk login" required
                    minlength="4">
                <p class="text-xs text-text-muted mt-1">Min. 4 karakter, tanpa spasi</p>
            </div>
            <div>
                <label class="block text-sm font-medium text-text mb-2">Password <span
                        class="text-red-500">*</span></label>
                <input type="password" name="password" class="form-input" placeholder="Password untuk login" required
                    minlength="6">
                <p class="text-xs text-text-muted mt-1">Min. 6 karakter</p>
            </div>
        </div>

        <!-- Data Pribadi -->
        <h3 class="text-lg font-semibold text-header border-b border-border pb-2 mt-4"><i
                class="fas fa-user mr-2"></i>Data Pribadi</h3>
        <div>
            <label class="block text-sm font-medium text-text mb-2">Nama Anggota <span
                    class="text-red-500">*</span></label>
            <input type="text" name="nama" class="form-input" placeholder="Nama lengkap" required>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
                <label class="block text-sm font-medium text-text mb-2">Tempat Lahir</label>
                <input type="text" name="tempat_lahir" class="form-input" placeholder="Kota kelahiran">
            </div>
            <div>
                <label class="block text-sm font-medium text-text mb-2">Tanggal Lahir</label>
                <input type="date" name="tanggal_lahir" class="form-input">
            </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
                <label class="block text-sm font-medium text-text mb-2">No. WhatsApp</label>
                <input type="text" name="no_whatsapp" class="form-input" placeholder="08xxxxxxxxxx">
            </div>
            <div>
                <label class="block text-sm font-medium text-text mb-2">Golongan Darah</label>
                <select name="golongan_darah" class="form-input">
                    <option value="">-- Pilih --</option>
                    <option value="A">A</option>
                    <option value="B">B</option>
                    <option value="AB">AB</option>
                    <option value="O">O</option>
                </select>
            </div>
        </div>

        <!-- Data Pekerjaan -->
        <h3 class="text-lg font-semibold text-header border-b border-border pb-2 mt-4"><i
                class="fas fa-briefcase mr-2"></i>Data Pekerjaan & Pendidikan</h3>
        <div>
            <label class="block text-sm font-medium text-text mb-2">Tempat Bekerja</label>
            <input type="text" name="tempat_bekerja" class="form-input" placeholder="Nama tempat bekerja">
        </div>
        <div>
            <label class="block text-sm font-medium text-text mb-2">Kategori Tempat Bekerja</label>
            <select name="kategori_tempat_bekerja" class="form-input">
                <option value="">-- Pilih Kategori --</option>
                <option value="Apotek">Apotek</option>
                <option value="Rumah Sakit">Rumah Sakit</option>
                <option value="Puskesmas">Puskesmas</option>
                <option value="Klinik">Klinik</option>
                <option value="Industri Farmasi">Industri Farmasi</option>
                <option value="PBF">PBF</option>
                <option value="Instansi Pemerintah">Instansi Pemerintah</option>
                <option value="Lainnya">Lainnya</option>
            </select>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
                <label class="block text-sm font-medium text-text mb-2">Kampus</label>
                <input type="text" name="kampus" class="form-input" placeholder="Nama kampus">
            </div>
            <div>
                <label class="block text-sm font-medium text-text mb-2">Provinsi Kampus</label>
                <select name="provinsi_kampus" class="form-input">
                    <option value="">-- Pilih Provinsi --</option>
                    <option value="ACEH">Aceh</option>
                    <option value="SUMATERA UTARA">Sumatera Utara</option>
                    <option value="SUMATERA BARAT">Sumatera Barat</option>
                    <option value="RIAU">Riau</option>
                    <option value="JAMBI">Jambi</option>
                    <option value="SUMATERA SELATAN">Sumatera Selatan</option>
                    <option value="BENGKULU">Bengkulu</option>
                    <option value="LAMPUNG">Lampung</option>
                    <option value="KEPULAUAN BANGKA BELITUNG">Kep. Bangka Belitung</option>
                    <option value="KEPULAUAN RIAU">Kep. Riau</option>
                    <option value="DKI JAKARTA">DKI Jakarta</option>
                    <option value="JAWA BARAT">Jawa Barat</option>
                    <option value="JAWA TENGAH">Jawa Tengah</option>
                    <option value="DI YOGYAKARTA">DI Yogyakarta</option>
                    <option value="JAWA TIMUR">Jawa Timur</option>
                    <option value="BANTEN">Banten</option>
                    <option value="BALI">Bali</option>
                    <option value="NUSA TENGGARA BARAT">Nusa Tenggara Barat</option>
                    <option value="NUSA TENGGARA TIMUR">Nusa Tenggara Timur</option>
                    <option value="KALIMANTAN BARAT">Kalimantan Barat</option>
                    <option value="KALIMANTAN TENGAH">Kalimantan Tengah</option>
                    <option value="KALIMANTAN SELATAN">Kalimantan Selatan</option>
                    <option value="KALIMANTAN TIMUR">Kalimantan Timur</option>
                    <option value="KALIMANTAN UTARA">Kalimantan Utara</option>
                    <option value="SULAWESI UTARA">Sulawesi Utara</option>
                    <option value="SULAWESI TENGAH">Sulawesi Tengah</option>
                    <option value="SULAWESI SELATAN">Sulawesi Selatan</option>
                    <option value="SULAWESI TENGGARA">Sulawesi Tenggara</option>
                    <option value="GORONTALO">Gorontalo</option>
                    <option value="SULAWESI BARAT">Sulawesi Barat</option>
                    <option value="MALUKU">Maluku</option>
                    <option value="MALUKU UTARA">Maluku Utara</option>
                    <option value="PAPUA BARAT">Papua Barat</option>
                    <option value="PAPUA">Papua</option>
                </select>
            </div>
        </div>
        <div>
            <label class="block text-sm font-medium text-text mb-2">Ijazah Kefarmasian</label>
            <select name="ijazah_kefarmasian" class="form-input">
                <option value="">-- Pilih --</option>
                <option value="SMF/SAA">SMF/SAA</option>
                <option value="D3 Farmasi">D3 Farmasi</option>
                <option value="S1 Farmasi">S1 Farmasi</option>
                <option value="Profesi Apoteker">Profesi Apoteker</option>
            </select>
        </div>

        <!-- Data Kefarmasian -->
        <h3 class="text-lg font-semibold text-header border-b border-border pb-2 mt-4"><i
                class="fas fa-id-card mr-2"></i>Data Kefarmasian</h3>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <div>
                <label class="block text-sm font-medium text-text mb-2">No. STR</label>
                <input type="text" name="no_str" class="form-input" placeholder="No. STR">
            </div>
            <div>
                <label class="block text-sm font-medium text-text mb-2">No. SIP</label>
                <input type="text" name="no_sip" class="form-input" placeholder="No. SIP">
            </div>
            <div>
                <label class="block text-sm font-medium text-text mb-2">Masa Aktif SIP</label>
                <input type="date" name="masa_aktif_sip" class="form-input">
            </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
                <label class="block text-sm font-medium text-text mb-2">No. KTAN</label>
                <input type="text" name="no_ktan" class="form-input" placeholder="No. KTAN">
            </div>
            <div>
                <label class="block text-sm font-medium text-text mb-2">Jenis Kartu</label>
                <select name="jenis_kartu" class="form-input">
                    <option value="KTA Baru">KTA Baru</option>
                    <option value="Perpanjangan KTA">Perpanjangan KTA</option>
                </select>
            </div>
        </div>

        <!-- Upload Foto -->
        <h3 class="text-lg font-semibold text-header border-b border-border pb-2 mt-4"><i
                class="fas fa-upload mr-2"></i>Upload Foto</h3>
        <div>
            <label class="block text-sm font-medium text-text mb-2"><i class="fas fa-camera text-header mr-1"></i> Foto
                <span class="text-red-500">*</span></label>
            <input type="file" name="foto" accept="image/*"
                class="form-input file:mr-4 file:py-1 file:px-3 file:rounded file:border-0 file:text-sm file:bg-blue-50 file:text-header"
                required>
            <p class="text-xs text-text-muted mt-1">Foto pas terbaru (JPG, PNG). Maks 5MB</p>
        </div>

        <!-- Surat Pernyataan -->
        <h3 class="text-lg font-semibold text-header border-b border-border pb-2 mt-4"><i
                class="fas fa-file-contract mr-2"></i>Surat Pernyataan Anggota</h3>
        <div class="bg-blue-50 border border-blue-200 rounded-xl p-5 text-sm text-text leading-relaxed">
            <p class="mb-3 font-medium">Dengan ini saya setuju dan bersedia menjadi anggota dengan syarat dan ketentuan
                dari OP PAFI Cabang Balikpapan, yaitu :</p>
            <ol class="list-[lower-alpha] pl-5 space-y-2 text-text-muted">
                <li>Sebagai dukungan materiil terhadap Organisasi, siap membayar iuran bulanan <strong
                        class="text-text">Rp. 10.000/Bulan</strong> selama setahun bagi anggota baru, dan 6 bulan sekali
                    bayar bagi anggota lama</li>
                <li>Terlibat kegiatan PAFI sebagai dukungan terhadap organisasi baik secara aktif atau pasif.</li>
                <li>Aplikatif terhadap peraturan dan ketentuan yang telah ditetapkan PP PAFI baik merujuk pada ADR ART
                    ataupun ketetapan Rakernas</li>
                <li>Responsif terhadap OP PAFI Balikpapan terkait pendataan sebagai dasar pengawasan bersama dengan
                    pihak Balai POM Dan Dinkes Kota Balikpapan</li>
                <li>Siap menjadi tenaga Profesional Tenaga Vokasi Farmasi yang handal dan bertanggungjawab.</li>
            </ol>
        </div>
        <div class="flex items-start gap-3 bg-gray-50 border border-border rounded-lg p-4">
            <input type="checkbox" id="setuju" required class="mt-1 w-5 h-5 accent-header rounded">
            <label for="setuju" class="text-sm text-text cursor-pointer">Saya telah membaca, memahami, dan
                <strong>menyetujui</strong> seluruh syarat dan ketentuan di atas sebagai calon anggota PAFI Cabang
                Balikpapan. <span class="text-red-500">*</span></label>
        </div>

        <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4 text-sm text-yellow-800">
            <i class="fas fa-info-circle mr-1"></i> Setelah pendaftaran berhasil, silakan <strong>login</strong> dengan
            username & password yang Anda buat untuk melakukan pembayaran iuran.
        </div>

        <button type="submit" class="btn-primary w-full justify-center py-3"><i class="fas fa-paper-plane"></i> Kirim
            Pendaftaran</button>
    </form>
</section>