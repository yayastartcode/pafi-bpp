<!-- Hero Image -->
<% if (settings.hero_bg) { %>
    <section class="w-full h-[400px] md:h-[500px] lg:h-[600px] bg-center bg-cover bg-no-repeat relative"
        style="background-image: url('/uploads/<%= settings.hero_bg %>');">
    </section>
    <% } %>

        <!-- Hero Text -->
        <section class="bg-white py-16 shadow-sm border-b border-gray-100">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
                <div
                    class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-blue-50 text-header text-sm font-medium mb-6 border border-blue-100">
                    <i class="fas fa-mortar-pestle"></i>
                    <%= settings.site_tagline || 'Persatuan Ahli Farmasi Indonesia' %>
                </div>
                <h1 class="text-4xl md:text-5xl font-extrabold text-text mb-4">
                    <%= settings.hero_title || 'PAFI Cabang Balikpapan' %>
                </h1>
                <p class="text-lg text-text-muted max-w-2xl mx-auto mb-8">
                    <%= settings.hero_subtitle || 'Bersama memajukan profesi kefarmasian di Kota Balikpapan.' %>
                </p>
                <div class="flex flex-col sm:flex-row gap-3 justify-center">
                    <a href="<%= settings.hero_btn_link || '/daftar' %>"
                        class="bg-header text-white font-semibold py-3 px-8 rounded-lg hover:opacity-90 transition inline-flex items-center justify-center gap-2">
                        <i class="fas fa-user-plus"></i>
                        <%= settings.hero_btn_text || 'Daftar Anggota' %>
                    </a>
                    <a href="#tentang"
                        class="border-2 border-border text-text font-semibold py-3 px-8 rounded-lg hover:bg-gray-50 transition inline-flex items-center justify-center gap-2">
                        <i class="fas fa-info-circle"></i> Tentang Kami
                    </a>
                </div>
            </div>
        </section>

        <!-- Tentang Organisasi -->
        <section id="tentang" class="py-16 bg-white">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="text-center mb-12">
                    <h2 class="text-3xl font-bold text-text mb-3">Tentang <span class="text-header">Organisasi</span>
                    </h2>
                    <p class="text-text-muted">Visi dan Misi <%= settings.site_name || 'PAFI Cabang Balikpapan' %>
                    </p>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
                    <div class="card p-8 card-hover">
                        <div class="w-14 h-14 rounded-xl bg-blue-50 flex items-center justify-center mb-4">
                            <i class="fas fa-eye text-header text-2xl"></i>
                        </div>
                        <h3 class="text-xl font-bold text-text mb-3">Visi</h3>
                        <p class="text-text-muted leading-relaxed">
                            <%= settings.visi
                                || 'Menjadi organisasi profesi farmasi yang profesional, mandiri, dan berkontribusi dalam peningkatan derajat kesehatan masyarakat.'
                                %>
                        </p>
                    </div>
                    <div class="card p-8 card-hover">
                        <div class="w-14 h-14 rounded-xl bg-blue-50 flex items-center justify-center mb-4">
                            <i class="fas fa-bullseye text-header text-2xl"></i>
                        </div>
                        <h3 class="text-xl font-bold text-text mb-3">Misi</h3>
                        <ul class="text-text-muted space-y-2">
                            <% (settings.misi
                                || 'Meningkatkan kompetensi anggota|Menyelenggarakan kegiatan ilmiah|Memperkuat jejaring'
                                ).split('|').forEach(function(m) { %>
                                <li class="flex items-start gap-2"><i
                                        class="fas fa-check text-success mt-1 flex-shrink-0"></i>
                                    <%= m.trim() %>
                                </li>
                                <% }); %>
                        </ul>
                    </div>
                </div>
            </div>
        </section>

        <!-- Berita -->
        <section class="py-16 bg-page-bg">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="flex items-center justify-between mb-8">
                    <div>
                        <h2 class="text-3xl font-bold text-text">Berita <span class="text-header">Terbaru</span></h2>
                        <p class="text-text-muted mt-1">Informasi dan berita terkini</p>
                    </div>
                    <a href="/berita" class="text-header font-medium text-sm hover:underline">Lihat semua →</a>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <% if (berita.length> 0) { berita.forEach(function(b) { %>
                        <div class="card overflow-hidden card-hover">
                            <div class="h-1 bg-header"></div>
                            <div class="p-6">
                                <div class="text-xs text-text-muted mb-2"><i class="fas fa-calendar mr-1"></i>
                                    <%= b.tanggal ? new Date(b.tanggal).toLocaleDateString('id-ID',
                                        {day:'numeric',month:'long',year:'numeric'}) : '-' %>
                                </div>
                                <h3 class="font-semibold text-text mb-2 line-clamp-2">
                                    <%= b.judul %>
                                </h3>
                                <p class="text-text-muted text-sm line-clamp-3"><%- (b.konten || ''
                                        ).replace(/<[^>]*>/g,
                                        '').substring(0, 150) %></p>
                            </div>
                        </div>
                        <% }); } else { %>
                            <div class="col-span-3 card p-8 text-center text-text-muted"><i
                                    class="fas fa-newspaper text-3xl mb-3"></i>
                                <p>Belum ada berita</p>
                            </div>
                            <% } %>
                </div>
            </div>
        </section>

        <!-- Info Kegiatan -->
        <section class="py-16 bg-white">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="flex items-center justify-between mb-8">
                    <div>
                        <h2 class="text-3xl font-bold text-text">Info <span class="text-header">Kegiatan</span></h2>
                        <p class="text-text-muted mt-1">Kegiatan yang akan datang</p>
                    </div>
                    <a href="/kegiatan" class="text-header font-medium text-sm hover:underline">Lihat semua →</a>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <% if (kegiatan.length> 0) { kegiatan.forEach(function(k) { %>
                        <div class="card p-6 card-hover">
                            <div class="w-12 h-12 rounded-xl bg-blue-50 flex items-center justify-center mb-4">
                                <i class="fas fa-calendar-alt text-header text-xl"></i>
                            </div>
                            <h3 class="font-semibold text-text mb-2">
                                <%= k.nama_kegiatan %>
                            </h3>
                            <p class="text-text-muted text-sm line-clamp-3">
                                <%= k.tujuan || k.bidang || 'Info kegiatan' %>
                            </p>
                            <a href="/kegiatan/<%= k.id %>/daftar"
                                class="mt-4 inline-flex items-center gap-1 text-header text-sm font-medium hover:underline">
                                <i class="fas fa-arrow-right"></i> Daftar
                            </a>
                        </div>
                        <% }); } else { %>
                            <div class="col-span-3 card p-8 text-center text-text-muted"><i
                                    class="fas fa-calendar text-3xl mb-3"></i>
                                <p>Belum ada kegiatan mendatang</p>
                            </div>
                            <% } %>
                </div>
            </div>
        </section>

        <!-- Kontak -->
        <section class="py-16 bg-header text-white">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="text-center mb-10">
                    <h2 class="text-3xl md:text-4xl font-bold mb-4">Hubungi Kami</h2>
                    <p class="text-white/80 max-w-xl mx-auto">Punya pertanyaan atau ingin bergabung? Jangan ragu
                        menghubungi kami melalui saluran berikut.</p>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto">
                    <!-- Sekretariat -->
                    <div class="bg-white/10 p-6 rounded-xl flex items-start gap-4">
                        <div class="w-12 h-12 rounded-full bg-white/20 flex items-center justify-center shrink-0">
                            <i class="fas fa-building text-2xl"></i>
                        </div>
                        <div>
                            <h3 class="font-bold text-lg mb-1">Sekretariat PAFI</h3>
                            <p class="text-white/80 text-sm">
                                <%= settings.contact_address || 'Belum diatur' %>
                            </p>
                        </div>
                    </div>

                    <!-- WhatsApp -->
                    <div class="bg-white/10 p-6 rounded-xl flex items-start gap-4">
                        <div
                            class="w-12 h-12 rounded-full bg-green-500/20 text-green-400 flex items-center justify-center shrink-0">
                            <i class="fab fa-whatsapp text-2xl"></i>
                        </div>
                        <div>
                            <h3 class="font-bold text-lg mb-1">WhatsApp</h3>
                            <a href="https://wa.me/<%= (settings.contact_whatsapp || '0811484010').replace(/\D/g, '') %>"
                                target="_blank" class="text-white/80 hover:text-white text-sm">
                                <%= settings.contact_whatsapp || '0811484010' %>
                            </a>
                        </div>
                    </div>

                    <!-- Website -->
                    <div class="bg-white/10 p-6 rounded-xl flex items-start gap-4">
                        <div
                            class="w-12 h-12 rounded-full bg-blue-500/20 text-blue-300 flex items-center justify-center shrink-0">
                            <i class="fas fa-globe text-2xl"></i>
                        </div>
                        <div>
                            <h3 class="font-bold text-lg mb-1">Website Resmi</h3>
                            <a href="<%= settings.contact_website ? (settings.contact_website.startsWith('http') ? settings.contact_website : 'https://' + settings.contact_website) : '#' %>"
                                target="_blank" class="text-white/80 hover:text-white text-sm break-all">
                                <%= settings.contact_website || 'Belum diatur' %>
                            </a>
                        </div>
                    </div>

                    <!-- Facebook -->
                    <div class="bg-white/10 p-6 rounded-xl flex items-start gap-4">
                        <div
                            class="w-12 h-12 rounded-full bg-blue-600/20 text-blue-400 flex items-center justify-center shrink-0">
                            <i class="fab fa-facebook-f text-2xl"></i>
                        </div>
                        <div>
                            <h3 class="font-bold text-lg mb-1">Facebook</h3>
                            <a href="<%= settings.contact_facebook ? (settings.contact_facebook.startsWith('http') ? settings.contact_facebook : 'https://facebook.com/' + settings.contact_facebook) : '#' %>"
                                target="_blank" class="text-white/80 hover:text-white text-sm break-all">
                                <%= settings.contact_facebook || 'Belum diatur' %>
                            </a>
                        </div>
                    </div>

                    <!-- Instagram -->
                    <div class="bg-white/10 p-6 rounded-xl flex items-start gap-4">
                        <div
                            class="w-12 h-12 rounded-full bg-pink-500/20 text-pink-400 flex items-center justify-center shrink-0">
                            <i class="fab fa-instagram text-2xl"></i>
                        </div>
                        <div>
                            <h3 class="font-bold text-lg mb-1">Instagram</h3>
                            <a href="<%= settings.contact_instagram ? (settings.contact_instagram.startsWith('http') ? settings.contact_instagram : 'https://instagram.com/' + settings.contact_instagram) : '#' %>"
                                target="_blank" class="text-white/80 hover:text-white text-sm break-all">
                                <%= settings.contact_instagram || 'Belum diatur' %>
                            </a>
                        </div>
                    </div>

                    <!-- Youtube -->
                    <div class="bg-white/10 p-6 rounded-xl flex items-start gap-4">
                        <div
                            class="w-12 h-12 rounded-full bg-red-500/20 text-red-500 flex items-center justify-center shrink-0">
                            <i class="fab fa-youtube text-2xl"></i>
                        </div>
                        <div>
                            <h3 class="font-bold text-lg mb-1">YouTube</h3>
                            <a href="<%= settings.contact_youtube ? (settings.contact_youtube.startsWith('http') ? settings.contact_youtube : 'https://youtube.com/' + settings.contact_youtube) : '#' %>"
                                target="_blank" class="text-white/80 hover:text-white text-sm break-all">
                                <%= settings.contact_youtube || 'Belum diatur' %>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </section>