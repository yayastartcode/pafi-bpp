<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="text-center mb-12">
        <h1 class="text-3xl md:text-4xl font-bold mb-3">Info <span class="text-header">Kegiatan</span></h1>
        <p class="text-text-muted">Kegiatan PAFI Cabang Balikpapan</p>
    </div>

    <!-- Kegiatan Mendatang -->
    <div class="mb-16">
        <h2 class="text-2xl font-bold mb-6 flex items-center gap-2"><i class="fas fa-calendar-alt text-primary"></i>
            Kegiatan Mendatang</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <% if (upcoming.length> 0) { upcoming.forEach(function(k) { %>
                <div class="card rounded-2xl p-6 card-hover">
                    <div class="w-12 h-12 rounded-xl bg-indigo-50 flex items-center justify-center mb-4">
                        <i class="fas fa-calendar-plus text-indigo-600 text-xl"></i>
                    </div>
                    <h3 class="font-semibold text-text mb-2">
                        <%= k.nama_kegiatan %>
                    </h3>
                    <p class="text-sm text-text-muted mb-1"><i class="fas fa-layer-group mr-1"></i>
                        <%= k.bidang || '-' %>
                    </p>
                    <p class="text-sm text-text-muted mb-1"><i class="fas fa-bullseye mr-1"></i>
                        <%= k.tujuan || '-' %>
                    </p>
                    <p class="text-sm text-text-muted mb-3"><i class="fas fa-users mr-1"></i> Target: <%= k.target_peserta
                            || '-' %> peserta</p>
                    <a href="/kegiatan/<%= k.id %>/daftar" class="btn-primary text-sm py-2 px-4 inline-flex">
                        <i class="fas fa-user-plus"></i> Daftar
                    </a>
                </div>
                <% }); } else { %>
                    <div class="col-span-3 text-center py-8 text-text-muted">Belum ada kegiatan mendatang</div>
                    <% } %>
        </div>
    </div>

    <!-- Kegiatan Terealisasi -->
    <div>
        <h2 class="text-2xl font-bold mb-6 flex items-center gap-2"><i class="fas fa-check-circle text-green-600"></i>
            Kegiatan Terealisasi</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <% if (past.length> 0) { past.forEach(function(k) { %>
                <div class="card rounded-2xl p-6 card-hover">
                    <div class="flex items-center justify-between mb-4">
                        <h3 class="font-semibold text-text">
                            <%= k.nama_kegiatan %>
                        </h3>
                        <span class="text-xs text-text-muted">
                            <%= k.tanggal ? new Date(k.tanggal).toLocaleDateString('id-ID') : '-' %>
                        </span>
                    </div>
                    <div class="text-sm text-text-muted mb-3">
                        <span><i class="fas fa-user-tie mr-1"></i>
                            <%= k.ketua_panitia || '-' %>
                        </span>
                        <span class="ml-4"><i class="fas fa-users mr-1"></i>
                            <%= k.jumlah_peserta || '-' %> peserta
                        </span>
                    </div>
                    <div class="flex gap-2 flex-wrap">
                        <% [k.foto1,k.foto2,k.foto3,k.foto4,k.foto5].filter(Boolean).forEach(function(f) { %>
                            <img src="/uploads/<%= f %>"
                                class="w-16 h-16 rounded-lg object-cover border border-border" alt="">
                            <% }); %>
                    </div>
                </div>
                <% }); } else { %>
                    <div class="col-span-2 text-center py-8 text-text-muted">Belum ada kegiatan terealisasi</div>
                    <% } %>
        </div>
    </div>
</section>