<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="text-center mb-12">
        <h1 class="text-3xl md:text-4xl font-bold mb-3">Berita & <span class="text-header">Informasi</span></h1>
        <p class="text-text-muted">Kabar terkini dan informasi penting seputar kefarmasian</p>
    </div>

    <!-- Berita Lainnya -->
    <div class="mb-16">
        <h2 class="text-2xl font-bold mb-6 flex items-center gap-2"><i class="fas fa-newspaper text-primary"></i> Berita
            Terbaru</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <% if (berita.length> 0) { berita.forEach(function(b) { %>
                <div class="card rounded-2xl overflow-hidden card-hover">
                    <div class="h-2 bg-gradient-to-r from-primary to-accent"></div>
                    <div class="p-6">
                        <div class="text-xs text-text-muted mb-2"><i class="fas fa-calendar mr-1"></i>
                            <%= b.tanggal ? new Date(b.tanggal).toLocaleDateString('id-ID',
                                {day:'numeric',month:'long',year:'numeric'}) : '-' %>
                        </div>
                        <h3 class="font-semibold text-text mb-3">
                            <%= b.judul %>
                        </h3>
                        <div class="text-text-muted text-sm line-clamp-4"><%- (b.konten || '' ).replace(/<[^>]*>/g,
                                '').substring(0, 200) %></div>
                    </div>
                </div>
                <% }); } else { %>
                    <div class="col-span-3 text-center py-8 text-text-muted">Belum ada berita</div>
                    <% } %>
        </div>
    </div>

    <!-- SKP -->
    <div class="mb-16">
        <h2 class="text-2xl font-bold mb-6 flex items-center gap-2"><i class="fas fa-file-alt text-accent"></i> Tata
            Cara Pengisian SKP</h2>
        <div class="space-y-4">
            <% if (skp.length> 0) { skp.forEach(function(s) { %>
                <div class="card rounded-xl p-6">
                    <div class="flex items-center justify-between mb-2">
                        <h3 class="font-semibold text-text">
                            <%= s.judul %>
                        </h3>
                        <span class="text-xs text-text-muted">
                            <%= s.tanggal ? new Date(s.tanggal).toLocaleDateString('id-ID') : '-' %>
                        </span>
                    </div>
                    <div class="text-text-muted text-sm"><%- (s.konten || '' ).substring(0, 300) %></div>
                </div>
                <% }); } else { %>
                    <div class="text-center py-8 text-text-muted">Belum ada info SKP</div>
                    <% } %>
        </div>
    </div>


</section>